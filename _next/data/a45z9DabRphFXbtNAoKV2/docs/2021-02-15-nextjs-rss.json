<span class=\"token\" style=\"color:#999\">.</span><span class=\"token property-access maybe-class-name\">PlainDate</span><span class=\"token\" style=\"color:#999\">.</span><span class=\"token method property-access\" style=\"color:#DD4A68\">compare</span><span class=\"token\" style=\"color:#999\">(</span><span>b</span><span class=\"token\" style=\"color:#999\">.</span><span class=\"token property-access\">firstEdition</span><span class=\"token\" style=\"color:#999\">,</span><span> a</span><span class=\"token\" style=\"color:#999\">.</span><span class=\"token property-access\">firstEdition</span><span class=\"token\" style=\"color:#999\">)</span><span class=\"token\" style=\"color:#999\">)</span><span class=\"token\" style=\"color:#999\">;</span><span>\n</span>\n<span>  </span><span class=\"token\" style=\"color:#07a\">let</span><span> buf </span><span class=\"token\" style=\"color:#9a6e3a;background:hsla(0, 0%, 100%, .5)\">=</span><span> </span><span class=\"token template-string template-punctuation\" style=\"color:#690\">`</span><span class=\"token template-string\" style=\"color:#690\">&lt;?xml version=&quot;1.0&quot;?&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">&lt;rss version=&quot;2.0&quot;&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">  &lt;channel&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">    &lt;title&gt;sukawasatoru.com&lt;/title&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">    &lt;link&gt;</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">baseUrl</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">}</span><span class=\"token template-string\" style=\"color:#690\">&lt;/link&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">    &lt;description&gt;My description&lt;/description&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">    &lt;lastBuildDate&gt;</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\" style=\"color:#07a\">new</span><span class=\"token template-string interpolation\"> </span><span class=\"token template-string interpolation known-class-name\" style=\"color:#DD4A68\">Date</span><span class=\"token template-string interpolation\" style=\"color:#999\">(</span><span class=\"token template-string interpolation\" style=\"color:#999\">)</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">}</span><span class=\"token template-string\" style=\"color:#690\">&lt;/lastBuildDate&gt;\n</span><span class=\"token template-string\" style=\"color:#690\"></span><span class=\"token template-string template-punctuation\" style=\"color:#690\">`</span><span class=\"token\" style=\"color:#999\">;</span><span>\n</span>\n<span>  </span><span class=\"token\" style=\"color:#07a\">for</span><span> </span><span class=\"token\" style=\"color:#999\">(</span><span class=\"token\" style=\"color:#07a\">const</span><span> entry </span><span class=\"token\" style=\"color:#07a\">of</span><span> entries</span><span class=\"token\" style=\"color:#999\">)</span><span> </span><span class=\"token\" style=\"color:#999\">{</span><span>\n</span><span>    </span><span class=\"token\" style=\"color:#07a\">const</span><span> target </span><span class=\"token\" style=\"color:#9a6e3a;background:hsla(0, 0%, 100%, .5)\">=</span><span> </span><span class=\"token template-string template-punctuation\" style=\"color:#690\">`</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">baseUrl</span><span class=\"token template-string interpolation interpolation-punctuation\" st