an> </span><span class=\"token template-string template-punctuation\" style=\"color:#690\">`</span><span class=\"token template-string\" style=\"color:#690\">    &lt;item&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">      &lt;title&gt;</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">entry</span><span class=\"token template-string interpolation\" style=\"color:#999\">.</span><span class=\"token template-string interpolation property-access\">title</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">}</span><span class=\"token template-string\" style=\"color:#690\">&lt;/title&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">      &lt;link&gt;</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">target</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">}</span><span class=\"token template-string\" style=\"color:#690\">&lt;/link&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">      &lt;guid&gt;</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">target</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">}</span><span class=\"token template-string\" style=\"color:#690\">&lt;/guid&gt;\n</span><span class=\"token template-string\" style=\"color:#690\">      &lt;description&gt;&lt;![CDATA[</span><span class=\"token template-string interpolation interpolation-punctuation\" style=\"color:#999\">${</span><span class=\"token template-string interpolation\">mdxSource</span><span class=\"token template-string inter